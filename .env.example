# ─── Auth ──────────────────────────────────────────────────────────────────
# Password for the Comms web UI. In production (NODE_ENV=production), both of
# these MUST be set or the server refuses to start. In dev they default to "dev".
AUTH_PASSWORD=
# HMAC secret for signing session cookies. Generate with: openssl rand -hex 32
SESSION_SECRET=

# ─── Integration API ───────────────────────────────────────────────────────
# Bearer token for the Gloss → Comms push endpoint (/api/gloss/contacts) and
# the legacy /api/debug endpoints. Generate with: openssl rand -hex 32
API_KEY=

# ─── Google OAuth (Gmail + Calendar) ───────────────────────────────────────
# Create credentials at https://console.cloud.google.com
#   APIs & Services → Credentials → Create OAuth 2.0 Client ID (Web application)
#   Authorized redirect URI: http://localhost:3748/api/gmail/callback  (dev)
#                            https://comms-nc.fly.dev/api/gmail/callback  (prod)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Public origin used to build the OAuth redirect URI. Defaults to
# http://localhost:${PORT} in dev.
PUBLIC_ORIGIN=

# ─── Gemini (AI insights + meeting briefs) ─────────────────────────────────
# Create a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ─── Storage ───────────────────────────────────────────────────────────────
# Where the SQLite DB lives. Defaults to ~/Library/Application Support/comms/comms.db
# On Fly.io this is set to /data/comms.db (persistent volume).
COMMS_DB_PATH=

# ─── Misc ──────────────────────────────────────────────────────────────────
# Default: 3748
PORT=
