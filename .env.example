# Google OAuth — required for Gmail integration
# Create credentials at https://console.cloud.google.com
#   APIs & Services → Credentials → Create OAuth 2.0 Client ID (Web application)
#   Authorized redirect URI: http://localhost:3748/api/gmail/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional — default is 3748
PORT=3748

# Secret for the tunnel integration API — generate with: openssl rand -hex 32
# Required when exposing via Cloudflare Tunnel or any public URL
API_KEY=
